def process_text(content, shift):
    new_words = []

    for i in content:
        asci = ord(i) + shift
        new_letter = chr(asci)
        new_words.append(new_letter)

    return "".join(new_words)
print("1 - encrypt a file ")
print("2 - Decrypt a file")
user=input("enter an option from above options(1-2) : ")
if user=="1":
   try:
    name=input("Enter file name(without .txt): ")
    with open(f"{name}.txt","r") as file:
     content=file.read()
     result=process_text(content,+1)
    encrypt_filename=input("Enter a name for encrypted file(without.txt): ")
    with open(f"{encrypt_filename}.txt",'w')as file:
      file.write(result)
      print("File encrypted sucessfully ")
   except FileNotFoundError:
     print(f"Error! File named '{name}' does not exist in the current folder.")
